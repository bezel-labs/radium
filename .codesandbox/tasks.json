{
  "$schema": "https://codesandbox.io/schemas/tasks.json",
  "setupTasks": [
    { "name": "Install dependencies", "command": "npm install" }
  ],
  "tasks": {
    "auth": {
      "name": "Auth",
      "command": "npm run auth",
      "runAtStart": true,
      "preview": { "port": 5001 }
    },
    "dashboard": {
      "name": "Dashboard",
      "command": "npm run dashboard",
      "runAtStart": true,
      "preview": { "port": 5002 }
    },
    "marketing": {
      "name": "Marketing",
      "command": "npm run marketing",
