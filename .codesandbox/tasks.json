{
  // These tasks will run in order when initializing your CodeSandbox project.
  // A clean boot (incl. `sdk.sandboxes.restart`) replays these — so pulling the
  // latest GitHub code here makes the preview self-update on restart.
  "setupTasks": [
    {
      // Update to the latest pushed code before installing/building. Hard reset so
      // a clean, fast-forwardable tree (discards any live preview-only file overrides).
      "command": "git fetch origin && git reset --hard origin/main",
      "name": "Pull latest"
    },
    {
      "command": "npm i",
      "name": "Installing Dependencies"
    },
    {
      // radium-context / radium-fonts export from ./dist (tsc output); Storybook's
      // Vite can't resolve them until built. @radium/ui is fine (exports point at src).
      "command": "npm run build --workspace=radium-context --workspace=radium-fonts",
      "name": "Building Packages"
    }
  ],

  // These tasks can be run from CodeSandbox. Running one will open a log in the app.
  "tasks": {
    "storybook": {
      "name": "Storybook",
      "command": "npm run storybook",
      "runAtStart": true,
      "preview": {
        "port": 5004
      }
    }
  }
}
