      "preview": { "port": 5003 }
    },
    "storybook": {
      "name": "Storybook",
      "command": "npm run storybook",
      "runAtStart": true,
      "preview": { "port": 5004 }
    },
    "dev-all": {
      "name": "All (turbo)",
      "command": "npm run dev"
    }
  }
}
