{
  "name": "radium",
  "version": "0.0.1",
  "private": false,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "dashboard": "npm run dev --workspace=@radium/dashboard",
    "marketing": "npm run dev --workspace=@radium/marketing",
    "auth": "npm run dev --workspace=@radium/auth",
    "storybook": "npm run dev --workspace=@radium/storybook",
    "build:storybook": "npm run build --workspace=@radium/storybook",
    "tokens": "npm run build --workspace=radium && radium build --input design-tokens.json --output packages/ui/src/styles/variables.css --contexts-output packages/ui/src/styles/contexts.ts --fonts-output packages/ui/src/styles/fonts.ts"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
