{
  "name": "radium",
  "version": "0.0.1",
  "private": false,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "storybook": "npm run dev --workspace=@radium/storybook",
    "build:storybook": "npm run build --workspace=@radium/storybook",
    "template:build": "csb build . --ports 5004 --vm-tier Micro --name Radium",
    "tokens": "style-accelerator build"
  },
  "devDependencies": {
    "@codesandbox/sdk": "^2.4.2",
    "@keypuncherlabs/style-accelerator": "^0.0.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
