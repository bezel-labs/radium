{
  "name": "radium",
  "version": "0.0.0",
  "type": "module",
  "private": false,
  "description": "Convert a W3C Design Tokens (DTCG) file into a scoped variables.css, with one CSS scope per context.",
  "keywords": [
    "design-tokens",
    "dtcg",
    "css-variables",
    "css-custom-properties",
    "theming",
    "style-dictionary"
  ],
  "license": "MIT",
  "bin": {
    "radium": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write \"**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.1.0",
    "eslint": "^9.39.2",
    "globals": "^17.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
