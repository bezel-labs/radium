{
  "$schema": "https://www.designtokens.org/schemas/2025-10.schema.json",
  "base": {
    "color": {
      "green": {
        "500": {
          "$root": {
            "$value": { "colorSpace": "oklch", "components": [0.8, 0.18, 151.7], "hex": "#4ADE80", "alpha": 1 }
          },
          "$type": "color"
        }
      },
      "aqua": {
        "500": {
          "$root": {
            "$value": { "colorSpace": "oklch", "components": [0.75, 0.12, 200], "hex": "#3DD6D0", "alpha": 1 }
          },
          "$type": "color"
        }
      },
      "neutral": {
        "foreground": {
          "dark": { "$value": { "colorSpace": "oklch", "components": [0.93, 0.003, 173.9] } },
          "light": { "$value": { "colorSpace": "oklch", "components": [0.36, 0.044, 186.5] } },
          "$root": { "$value": { "colorSpace": "oklch", "components": [0.31, 0.082, 298.1] } },
          "$type": "color",
          "$extensions": {
            "com.tokendesigner.app": {
              "exportName": ["foreground", "card-foreground", "popover-foreground"]
            }
          }
        }
      }
    },
    "typography": {
      "font-family": {
        "sans": {
          "$root": { "$value": ["Geist Variable", "sans-serif"] },
          "$type": "fontFamily",
          "$extensions": { "com.tokendesigner.app": { "exportName": ["font-sans"] } }
        }
      },
      "font-size": {
        "sm": {
          "$root": { "$value": { "value": 14, "unit": "px" } },
          "$type": "dimension"
        }
      }
    },
    "spacing": {
      "md": {
        "$root": { "$value": { "value": 16, "unit": "px" } },
        "$type": "dimension",
        "$extensions": { "com.tokendesigner.app": { "exportName": [""] } }
      }
    }
  },
  "semantic": {
    "color": {
      "primary": {
        "default": {
          "dark": { "$value": "{base.color.aqua.500}" },
          "$root": { "$value": "{base.color.green.500}" },
          "$type": "color",
          "$extensions": { "com.tokendesigner.app": { "exportName": ["primary"] } }
        },
        "foreground": {
          "$root": { "$value": "{base.color.neutral.foreground}" },
          "$type": "color",
          "$extensions": { "com.tokendesigner.app": { "exportName": ["primary-foreground"] } }
        }
      }
    }
  }
}
