{
  "name": "@keypuncherlabs/storybook-tools",
  "version": "0.0.0",
  "type": "module",
  "private": false,
  "description": "Runtime helpers for the Radium Storybook preview: resolve the initial theme context (URL/localStorage) and load design-token web fonts. One folder per tool so more can be added as needed.",
  "keywords": [
    "storybook",
    "design-tokens",
    "theme",
    "context",
    "fonts",
    "web-fonts"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write \"**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "globals": "^17.2.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
